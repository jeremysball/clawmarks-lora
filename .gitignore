# secrets, never commit
.envrc
.env
runpod-ssh/

# ephemeral working notes, per CLAUDE.md convention: not tracked
TODO.txt

# archive: superseded/unrelated material kept on disk, not in history
archive/

# expedition/leg config: lives under $XDG_STATE_HOME/clawmarks/expeditions/, not the repo (ADR 0001)
/expeditions/
# docker-compose's CLAWMARKS_STATE_DIR bind mount target (docker-compose.yml): on a host that
# runs docker-compose from a repo checkout, this is where generation output and expedition/leg
# config actually land, so it must never be tracked.
/state/

# large binaries and generated media: regenerable from scripts + prompts, don't belong in git
*.safetensors
*.zip
*.tar.gz
*.log
art/
art.zip
art_batch/
checkpoints_v3_fixed/
curated_25/
dino_top25/
full_batch_sheet/
gen/
review_sheets/
samples/
training_samples_v3_fixed/
valgrid/
# uncanny_sweep, uncanny_sweep2, probe_uncanny, probe_strength moved out of notes/ entirely,
# to $XDG_STATE_HOME/clawmarks (see config.py's STATE_DIR), so they no longer need entries here.
notes/uncanny_seedrun1/
*.backup_candidate_seeds_*
.playwright-mcp/
tests/fixtures/sample_sweep/notes/uncanny_sweep/*.html
tests/fixtures/sample_sweep/notes/uncanny_sweep/*.js
tests/fixtures/sample_sweep/notes/uncanny_sweep/embeddings.npz
tests/fixtures/sample_sweep/notes/uncanny_sweep/user_ratings.json
*.png
*.jpg
*.jpeg
!corrected_dataset_extract/*.jpg
!tests/fixtures/**/*.jpg
# curation_server.py opens this at import time; without a real file on disk, every fresh
# checkout (CI, Docker build) fails to import the module at all.
!src/clawmarks/static/favicon.png

# python
__pycache__/
*.pyc
venv/
